  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 27429c62b6bba3c4b87c3cf633b97d30, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  TextDisplay: {fileID: 1004995778}
  sentences:
  - Welcome to the AIMM building.%
  - "Since it\u2019s your first day, let me give you a rundown of$how things work
    around here. %"
  - "Recently, our building has been experiencing some\u2026$oddities every night.
    %"
  - 'We kept finding these strange sightings scattered$around the building.% '
  - 'Luckily for you, we discovered a remedy.% '
  - 'A couple of kids from the Science Complex created$a system to get rid of them.$Hell
    if I know how it works.% '
  - "That\u2019s where you come in.%"
  - "You report these entities and we\u2019ll dispose of them for$you%. "
  - To help with your reporting, we have separated these$entities into five categories.%
  - Glitch for entities that live in screens.%
  - Pareidolia for entities that live in images or walls.%
  - Peepers for entities that live in windows.%
  - 'Tulpas for entities that are physically present. They''re very loud and they''re
    known to get aggressive $after a few seconds.% '
  - "And lastly other for any entities that don\u2019t fit$any of these categories.% "
  - 'To control this system, press the left and right arrow keys on your provided
    keyboard to switch between the camera views.% '
  - 'You can also press the space bar to show or hide your report screen.%  '
  - 'On this report screen, you can click the buttons to set$the location and type
    of the entity and then hit the submit button to submit your report.% '
  - 'With that being said, good luck and godspeed!% '
  - -M.R.%
  typingspeed: 0.04
  continuebutton: {fileID: 302060162}
  startbutton: {fileID: 1253355472}
  dialoguePanel: {fileID: 2028902747}
  click: {fileID: 1212507742}
  playSound: 0
  isGameScene: 0
